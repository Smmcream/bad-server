{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "lib": ["es2020"],
        "moduleResolution": "node10",
        "baseUrl": "./src",
        "rootDir": "./src",
        "allowJs": true,
        "checkJs": false,
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
